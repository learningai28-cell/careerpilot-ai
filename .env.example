VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# PostHog — error monitoring + analytics. Get these from your PostHog
# project settings after creating a free account at posthog.com.
# Leave unset for local dev; analytics.ts no-ops without a key.
VITE_POSTHOG_KEY=phc_your-project-api-key
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Set as an Edge Function secret, NOT here (this file is client-side only):
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
